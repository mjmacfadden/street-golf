rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User's own courses (private)
    match /users/{uid}/courses/{courseId} {
      allow read, write: if request.auth.uid == uid;
    }

    // User's own rounds (private)
    match /users/{uid}/rounds/{roundId} {
      allow read, write: if request.auth.uid == uid;
    }

    // User's favorite courses (private)
    match /users/{uid}/favorites/{courseId} {
      allow read, write: if request.auth.uid == uid;
    }

    // Public courses - anyone can read, authenticated users can write
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User profile
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
  }
}
