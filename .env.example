# Google Maps Platform API Key
# Get your key from: https://console.cloud.google.com/
# Enable these APIs in your Google Cloud project:
# - Maps JavaScript API
# - Places API
# - Distance Matrix API (optional)
VITE_GOOGLE_MAPS_API_KEY=AIzaSyAVHLglxnboeHJQ5cJ0x1CQEe8BeCrkzlI

# Alternative naming (also supported):
GOOGLE_MAPS_PLATFORM_KEY=AIzaSyAVHLglxnboeHJQ5cJ0x1CQEe8BeCrkzlI

# Admin User ID (super user for moderation access)
# Get the Firebase UID from your Firebase Console → Authentication → Users
# Only this user will have access to the Admin Panel
VITE_ADMIN_UID=your_admin_uid_here
